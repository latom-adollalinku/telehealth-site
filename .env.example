# Cal.com Booking (set up at cal.com)
NEXT_PUBLIC_CAL_LINK=latom-wellness/consultation

# Helcim Card Processing (get at helcim.com/developers)
NEXT_PUBLIC_HELCIM_TOKEN=your_helcim_token_here

# PayPal Integration (get at developer.paypal.com)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here
NEXT_PUBLIC_PAYPAL_MODE=sandbox

# Zelle Payment Details (your practice account)
NEXT_PUBLIC_ZELLE_EMAIL=pay@latomwellness.com

# Venmo Payment Details (your practice account)
NEXT_PUBLIC_VENMO_USERNAME=latom-wellness

# Practice Contact Info
NEXT_PUBLIC_PHONE=6784040730

# Application URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Notification Email (for booking requests)
NOTIFICATION_EMAIL=anesbrothers@gmail.com

# Email Service (SendGrid, Resend, etc. - optional)
SENDGRID_API_KEY=your_sendgrid_api_key_here
RESEND_API_KEY=your_resend_api_key_here
